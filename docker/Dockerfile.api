FROM golang:1.24-alpine AS builder
RUN apk add --no-cache git
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /gitplane-api ./cmd/server

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /gitplane-api /usr/local/bin/gitplane-api
COPY migrations /migrations
EXPOSE 8080
ENTRYPOINT ["gitplane-api"]
