FROM golang:1.24-alpine AS builder
RUN apk add --no-cache git
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /gitplane-agent ./agent

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /gitplane-agent /usr/local/bin/gitplane-agent
ENTRYPOINT ["gitplane-agent"]
